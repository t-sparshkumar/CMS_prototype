PORT=8055
NODE_ENV=development
DB_CLIENT=sqlite3
DB_FILE=./data/cms.db
SECRET_KEY=change-me-in-production
UPLOAD_DIR=./uploads
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
ADMIN_UI_URL=http://localhost:5173

