PORT=8055
NODE_ENV=development
SECRET_KEY=change-me-in-production
UPLOAD_DIR=./uploads
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
ADMIN_UI_URL=http://localhost:5173

# Local SQLite (default — no external credentials)
DB_CLIENT=sqlite3
DB_FILE=./data/cms.db

# Production — Supabase PostgreSQL (recommended for Railway deploy)
# DB_CLIENT=pg
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Or individual Postgres vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=cms
# DB_PASSWORD=cms
# DB_NAME=cms
