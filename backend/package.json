{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_OPTIONS='--import tsx' knex migrate:latest --knexfile knexfile.ts && NODE_OPTIONS='--import tsx' knex seed:run --knexfile knexfile.ts && node dist/index.js",
    "start:prod:migrate-only": "NODE_OPTIONS='--import tsx' knex migrate:latest --knexfile knexfile.ts && node dist/index.js",
    "migrate:latest": "NODE_OPTIONS='--import tsx' knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "NODE_OPTIONS='--import tsx' knex migrate:rollback --knexfile knexfile.ts",
    "seed:run": "NODE_OPTIONS='--import tsx' knex seed:run --knexfile knexfile.ts",
    "db:setup": "npm run migrate:latest && npm run seed:run",
    "schema:convert-directus": "NODE_OPTIONS='--import tsx' tsx src/scripts/convert-directus-snapshot.ts",
    "test:directus-adapter": "NODE_OPTIONS='--import tsx' tsx src/services/directus-snapshot.adapter.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "sharp": "^0.35.2",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
