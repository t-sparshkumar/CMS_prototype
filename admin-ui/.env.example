# ── Vercel production (recommended — works on mobile Safari) ──
# Proxy API through Vercel so login cookies stay same-origin.
BACKEND_URL=https://your-backend.up.railway.app
# Do NOT set VITE_API_URL when using BACKEND_URL.

# ── Alternative (cross-origin — may fail on mobile Safari) ──
# VITE_API_URL=https://your-backend.up.railway.app
